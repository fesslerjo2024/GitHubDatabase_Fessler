<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GitHub Portal</title>

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        :root {
            --dark:          #0d1117;
            --surface:       #161b22;
            --border:        #30363d;
            --accent:        #58a6ff;
            --accent-green:  #3fb950;
            --accent-orange: #d29922;
            --text:          #e6edf3;
            --text-muted:    #8b949e;
            --card-bg:       #1c2128;
            --hover:         #21262d;
            --danger:        #f85149;
        }

        body {
            background-color: var(--dark);
            color: var(--text);
            font-family: 'Segoe UI', system-ui, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Navbar */
        .portal-navbar { background-color: var(--surface); border-bottom: 1px solid var(--border); }
        .portal-navbar .navbar-brand { font-weight: 700; color: var(--accent) !important; }
        .portal-navbar .nav-link { color: var(--text-muted) !important; border-radius: 6px; transition: 0.15s; }
        .portal-navbar .nav-link:hover { color: var(--text) !important; background: var(--hover); }

        /* Page title */
        .page-title { font-size: 1.5rem; font-weight: 700; }
        .text-accent { color: var(--accent) !important; }

        /* Search */
        .search-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; }
        .search-card .input-group-text,
        .search-card .form-control { background: var(--dark); border-color: var(--border); color: var(--text); }
        .search-card .form-control::placeholder { color: var(--text-muted); }
        .search-card .form-control:focus {
            background: var(--dark); border-color: var(--accent); color: var(--text);
            box-shadow: 0 0 0 3px rgba(88,166,255,0.15);
        }

        /* Portal cards */
        .portal-card {
            background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px;
            transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
        }
        .portal-card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
        .card-icon {
            width: 36px; height: 36px; border-radius: 8px;
            background: rgba(88,166,255,0.1); display: flex; align-items: center;
            justify-content: center; color: var(--accent); font-size: 1.1rem; flex-shrink: 0;
        }
        .card-name { font-weight: 700; font-size: 0.95rem; color: var(--text); }
        .portal-card .border-top { border-color: var(--border) !important; }

        /* Form cards */
        .form-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
        .form-header { background: var(--surface); border-bottom: 1px solid var(--border); color: var(--text); padding: 1rem 1.5rem; }
        .form-header-edit  { background: rgba(210,153,34,0.1); border-bottom-color: rgba(210,153,34,0.3); color: var(--accent-orange); }
        .form-header-danger { background: rgba(248,81,73,0.1);  border-bottom-color: rgba(248,81,73,0.3);  color: var(--danger); }
        .field-label { color: var(--text-muted); font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.4rem; }
        .portal-input { background: var(--dark) !important; border-color: var(--border) !important; color: var(--text) !important; border-radius: 8px; }
        .portal-input::placeholder { color: var(--text-muted) !important; }
        .portal-input:focus { border-color: var(--accent) !important; box-shadow: 0 0 0 3px rgba(88,166,255,0.15) !important; }

        /* Buttons */
        .btn-add    { background: var(--accent);         border-color: var(--accent);         color: #0d1117; font-weight: 600; }
        .btn-add:hover    { background: #79b8ff; border-color: #79b8ff; color: #0d1117; }
        .btn-save   { background: var(--accent);         border-color: var(--accent);         color: #0d1117; font-weight: 600; }
        .btn-save:hover   { background: #79b8ff; color: #0d1117; }
        .btn-update { background: var(--accent-orange);  border-color: var(--accent-orange);  color: #0d1117; font-weight: 600; }
        .btn-update:hover { background: #e3b341; color: #0d1117; }
        .btn-visit {
            background: transparent; border: 1px solid var(--accent); color: var(--accent);
            font-size: 0.8rem; border-radius: 6px; padding: 0.25rem 0.6rem;
        }
        .btn-visit:hover { background: rgba(88,166,255,0.1); color: var(--accent); }
        .btn-outline-secondary { border-color: var(--border); color: var(--text-muted); }
        .btn-outline-secondary:hover { background: var(--hover); border-color: var(--border); color: var(--text); }
        .btn-outline-danger { border-color: rgba(248,81,73,0.4); color: var(--danger); }
        .btn-outline-danger:hover { background: rgba(248,81,73,0.1); border-color: var(--danger); color: var(--danger); }

        /* Dropdowns */
        .dropdown-menu { background: var(--surface); border-color: var(--border); border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.5); }
        .dropdown-item { color: var(--text); font-size: 0.875rem; }
        .dropdown-item:hover { background: var(--hover); color: var(--text); }
        .dropdown-item.text-danger:hover { background: rgba(248,81,73,0.1); color: var(--danger) !important; }
        .dropdown-divider { border-color: var(--border); }

        /* Alerts */
        .alert-success { background: rgba(63,185,80,0.1);  border-color: rgba(63,185,80,0.3);  color: var(--accent-green); }
        .alert-info    { background: rgba(88,166,255,0.1); border-color: rgba(88,166,255,0.2); color: var(--accent); }

        /* Misc */
        .delete-preview { background: rgba(248,81,73,0.05); border: 1px solid rgba(248,81,73,0.2); border-radius: 8px; }
        .empty-state { color: var(--text-muted); }
        .portal-footer { background: var(--surface); border-top: 1px solid var(--border); margin-top: auto; }
        .bg-light { background-color: var(--surface) !important; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark portal-navbar">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="PortalLinks" asp-action="Index">
                <i class="bi bi-grid-3x3-gap-fill"></i> GitHub Portal
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="PortalLinks" asp-action="Index">
                            <i class="bi bi-link-45deg me-1"></i>Portal Links
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="PortalLinks" asp-action="Create">
                            <i class="bi bi-plus-circle me-1"></i>Add Link
                        </a>
                    </li>
                </ul>
                <span class="navbar-text text-muted small">
                    <i class="bi bi-database me-1"></i>SQL Server LocalDB
                </span>
            </div>
        </div>
    </nav>

    <main class="container my-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span>@TempData["SuccessMessage"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="portal-footer py-3">
        <div class="container text-center">
            <small class="text-muted">
                GitHub Portal &mdash; ASP.NET Core MVC &bull; EF Core &bull; Bootstrap 5
            </small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
