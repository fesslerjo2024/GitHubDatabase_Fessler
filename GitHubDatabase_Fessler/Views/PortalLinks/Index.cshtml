@model IEnumerable<GitHubPortal.Models.PortalLink>

@{
    ViewData["Title"] = "Portal Links";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="page-title mb-1">
            <i class="bi bi-grid-3x3-gap-fill me-2 text-accent"></i>Portal Links
        </h1>
        <p class="text-secondary mb-0">@Model.Count() link(s) in your portal</p>
    </div>
    <a asp-action="Create" class="btn btn-add d-flex align-items-center gap-2">
        <i class="bi bi-plus-lg"></i> Add New Link
    </a>
</div>

<!-- Search Bar (Extra Credit) -->
<div class="card search-card mb-4">
    <div class="card-body py-3">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="searchQuery" class="form-control border-start-0 ps-0"
                       placeholder="  Search by name or description..."
                       value="@ViewBag.SearchQuery" />
            </div>
            <button type="submit" class="btn btn-outline-secondary px-3">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary px-3">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
    </div>
</div>

@if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-3 py-2">
        <i class="bi bi-funnel-fill"></i>
        Showing results for: <strong class="ms-1">"@ViewBag.SearchQuery"</strong>
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state text-center py-5">
        <i class="bi bi-inbox display-3 d-block mb-3"></i>
        <h4>No portal links found</h4>
        <p>
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
            {
                <span>No links matched your search. <a asp-action="Index">Clear search</a></span>
            }
            else
            {
                <span>Get started by <a asp-action="Create">adding your first link</a>.</span>
            }
        </p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card portal-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start mb-2">
                            <div class="card-icon me-3">
                                <i class="bi bi-link-45deg"></i>
                            </div>
                            <div class="dropdown ms-auto">
                                <button class="btn btn-sm btn-link text-muted p-0" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.PortalLinkId">
                                            <i class="bi bi-pencil me-2"></i>Edit
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.PortalLinkId">
                                            <i class="bi bi-trash me-2"></i>Delete
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <h5 class="card-name mb-1">@item.Name</h5>
                        <p class="card-text small flex-grow-1 mb-3" style="color: #cdd9e5;">@item.Description</p>

                        <div class="d-flex align-items-center justify-content-between mt-auto pt-2 border-top">
                            <a href="@item.Url" target="_blank" rel="noopener noreferrer"
                               class="btn btn-visit d-flex align-items-center gap-1">
                                <i class="bi bi-box-arrow-up-right"></i> Visit
                            </a>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.PortalLinkId"
                                   class="btn btn-sm btn-outline-secondary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.PortalLinkId"
                                   class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
